{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "modeldeck://scenechat/1/scene-analysis",
  "title": "SceneChat scene analysis",
  "type": "object",
  "additionalProperties": false,
  "required": ["summary", "objects", "relationships", "uncertainties", "safety_notes"],
  "properties": {
    "summary": {"type": "string", "minLength": 1, "maxLength": 360},
    "objects": {
      "type": "array",
      "maxItems": 8,
      "items": {
        "type": "object",
        "additionalProperties": false,
        "required": ["label", "description", "approximate_location"],
        "properties": {
          "label": {"type": "string", "minLength": 1, "maxLength": 48},
          "description": {"type": "string", "minLength": 1, "maxLength": 150},
          "approximate_location": {"type": "string", "minLength": 1, "maxLength": 48}
        }
      }
    },
    "relationships": {"type": "array", "maxItems": 3, "items": {"type": "string", "minLength": 1, "maxLength": 180}},
    "uncertainties": {"type": "array", "maxItems": 3, "items": {"type": "string", "minLength": 1, "maxLength": 180}},
    "safety_notes": {"type": "array", "maxItems": 1, "items": {"type": "string", "minLength": 1, "maxLength": 180}}
  }
}
