# Optional local launch configuration. Copy to .env and edit only the values you need.
# Existing process environment variables take precedence. Values are literal: no shell
# expansion or command substitution is performed.
MODELDECK_HOST=127.0.0.1
MODELDECK_MANAGEMENT_PORT=3600
MODELDECK_GATEWAY_PORT=8600
MODELDECK_DATA_DIR=.modeldeck
MODELDECK_LOG_DIR=var/log/workers
MODELDECK_OPEN_DAY=0
MODELDECK_SCENECHAT_API_KEY=local
MODELDECK_ALLOW_DOWNLOADS=0
MODELDECK_DIAGNOSTIC_CAPTURE=0
MODELDECK_DIFFUSION_TIMEOUT_SECONDS=900
MODELDECK_SCENECHAT_TIMEOUT_SECONDS=75
MODELDECK_TRANSLATION_TIMEOUT_SECONDS=65
MODELDECK_SPEECH_SYNTHESIS_TIMEOUT_SECONDS=130

# ModelDeck workload throttling. The external host TuneD policy remains read-only.
MODELDECK_THERMAL_THROTTLING_ENABLED=1
# Leave empty to select and pin the existing k10temp Tctl/Tdie APU sensor.
MODELDECK_THERMAL_SENSOR_ID=
MODELDECK_THERMAL_WARM_THRESHOLD_C=75
MODELDECK_THERMAL_HOT_THRESHOLD_C=80
MODELDECK_THERMAL_VERY_HOT_THRESHOLD_C=83
MODELDECK_THERMAL_CRITICAL_THRESHOLD_C=85
MODELDECK_THERMAL_WARM_RECOVERY_C=72
MODELDECK_THERMAL_HOT_RECOVERY_C=76
MODELDECK_THERMAL_VERY_HOT_RECOVERY_C=79
MODELDECK_THERMAL_TELEMETRY_STALE_SECONDS=15
MODELDECK_THERMAL_POLL_INTERVAL_SECONDS=5
MODELDECK_THERMAL_MINIMUM_STATE_DWELL_SECONDS=30
MODELDECK_THERMAL_RECOVERY_STEP_SECONDS=30
MODELDECK_THERMAL_RECOVERY_READING_COUNT=3
MODELDECK_THERMAL_HEAVY_CONCURRENCY=2
MODELDECK_THERMAL_BACKGROUND_CONCURRENCY=1
MODELDECK_THERMAL_WARM_SCENE_INTERVAL_SECONDS=5
MODELDECK_THERMAL_HOT_SCENE_INTERVAL_SECONDS=10
MODELDECK_THERMAL_STOP_AUTOMATIC_SCENE_WHEN_VERY_HOT=1
MODELDECK_HOST_POLICY_STATUS_ENABLED=1
MODELDECK_HOST_POLICY_SERVICE_NAME=framework-thermal-policy.service

# Optional trusted local overrides:
# HF_HOME=/mnt/work/models/huggingface
# HF_HUB_CACHE=/mnt/work/models/huggingface/hub
# MODELDECK_ROCM72_PYTHON=.venv-rocm72/bin/python
# MODELDECK_ROCM72_Q4_PYTHON=.venv-rocm72-q4/bin/python
# MODELDECK_MARIAN_PYTHON=.venv-marian-cpu/bin/python
# MODELDECK_QWEN_TTS_PYTHON=.venv-qwen3-tts-rocm72/bin/python
# MODELDECK_WHISPER_PYTHON=.venv-whisper-rocm72/bin/python
# MODELDECK_SPEECH_RECOGNITION_TIMEOUT_SECONDS=35
# MODELDECK_RUN_WHISPER_HARDWARE_TESTS=0
